# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/coaching_db

# Redis (Celery Broker + Result Backend)
REDIS_URL=redis://localhost:6379/0

# 腾讯云 COS 凭证（必须通过环境变量注入，不得硬编码）
COS_SECRET_ID=your_secret_id_here
COS_SECRET_KEY=your_secret_key_here
COS_REGION=ap-guangzhou
COS_BUCKET=your-bucket-name-1234567890

# 视频处理临时目录（处理完成后自动清理）
TMP_DIR=/tmp/coaching-advisor

# 应用设置
APP_ENV=development
LOG_LEVEL=INFO

# 视频扫描根路径（两侧物理隔离，禁止合并）
COS_VIDEO_ALL_COCAH=charhuang/tt_video/乒乓球合集【较新】/
COS_VIDEO_ALL_ATHLETE=charhuang/tt_video/athletes/

# Feature-021 视频内容清洗（默认值已合理，仅在压测/调优时覆盖）
# CURATION_JOB_TIMEOUT_SECONDS=600
# CURATION_LLM_TIMEOUT_SECONDS=5
# 应急回滚开关：True 时 KB 抽取跳过清洗强制门（business-workflow.md § 10 回滚剧本）。
# 仅在"清洗规则误伤导致 KB 读到的有效片段大量减少"时启用；命中后 extraction_jobs
# .output_summary.curation_bypass=true 留痕，恢复后立即设回 false 并重启 worker.
# KB_EXTRACTION_BYPASS_CURATION_GATE=false
